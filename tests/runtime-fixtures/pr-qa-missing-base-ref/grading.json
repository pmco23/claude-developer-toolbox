    },
    {
      "id": "reruns-bundled-diff-collector",
      "type": "tool_use",
      "name": "Bash",
      "inputContains": {
        "command": "node skills/pr-qa/scripts/collect-diff-context.js --base origin/main --json"
      }
    },
    {
      "id": "recovers-after-base-provided",
